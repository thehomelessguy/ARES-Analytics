rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated and belongs to the specified team
    function isTeamMember(teamId) {
      return request.auth != null && request.auth.token.team_id == teamId;
    }

    // Rules for team-defined robot rosters
    match /teams/{teamId}/robots/{robotId} {
      allow read: if request.auth != null;
      allow write: if isTeamMember(teamId);
    }

    // Rules for telemetry match summaries
    match /summaries/{sessionId} {
      allow read: if request.auth != null && isTeamMember(resource.data.teamId);
      allow write: if request.auth != null && isTeamMember(request.resource.data.teamId);
    }
  }
}
